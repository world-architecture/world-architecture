// pages/api/upload-youtube.js
// POST { videoUrl, title, description, tags, thumbnailUrl }
// Uses YouTube Data API v3

export default async function handler(req, res) {
  if (req.method !== "POST") return res.status(405).json({ error: "Method not allowed" });

  const { videoUrl, title, description, tags = [], thumbnailUrl } = req.body;
  if (!videoUrl || !title) return res.status(400).json({ error: "videoUrl and title required" });

  // Step 1: Get fresh access token via refresh token
  let accessToken;
  try {
    const tokenRes = await fetch("https://oauth2.googleapis.com/token", {
      method: "POST",
      headers: { "Content-Type": "application/x-www-form-urlencoded" },
      body: new URLSearchParams({
        client_id: process.env.YOUTUBE_CLIENT_ID,
        client_secret: process.env.YOUTUBE_CLIENT_SECRET,
        refresh_token: process.env.YOUTUBE_REFRESH_TOKEN,
        grant_type: "refresh_token"
      })
    });
    const tokenData = await tokenRes.json();
    accessToken = tokenData.access_token;
    if (!accessToken) throw new Error("Could not get access token: " + JSON.stringify(tokenData));
  } catch (err) {
    return res.status(500).json({ error: `YouTube auth failed: ${err.message}` });
  }

  // Step 2: Download video from Creatomate URL
  let videoBuffer;
  try {
    const videoRes = await fetch(videoUrl);
    videoBuffer = Buffer.from(await videoRes.arrayBuffer());
  } catch (err) {
    return res.status(500).json({ error: `Could not download video: ${err.message}` });
  }

  // Step 3: Upload to YouTube (resumable upload)
  try {
    // Init resumable upload
    const initRes = await fetch(
      "https://www.googleapis.com/upload/youtube/v3/videos?uploadType=resumable&part=snippet,status",
      {
        method: "POST",
        headers: {
          "Authorization": `Bearer ${accessToken}`,
          "Content-Type": "application/json",
          "X-Upload-Content-Type": "video/mp4",
          "X-Upload-Content-Length": videoBuffer.byteLength
        },
        body: JSON.stringify({
          snippet: {
            title,
            description,
            tags,
            categoryId: "22" // People & Blogs; use "19" for Travel
          },
          status: {
            privacyStatus: "public",
            selfDeclaredMadeForKids: false
          }
        })
      }
    );

    const uploadUrl = initRes.headers.get("location");
    if (!uploadUrl) throw new Error("No upload URL from YouTube");

    // Upload video bytes
    const uploadRes = await fetch(uploadUrl, {
      method: "PUT",
      headers: {
        "Content-Type": "video/mp4",
        "Content-Length": videoBuffer.byteLength
      },
      body: videoBuffer
    });

    const uploadData = await uploadRes.json();
    const videoId = uploadData.id;

    return res.status(200).json({
      success: true,
      videoId,
      youtubeUrl: `https://www.youtube.com/watch?v=${videoId}`,
      status: uploadData.status?.uploadStatus
    });
  } catch (err) {
    return res.status(500).json({ error: `YouTube upload failed: ${err.message}` });
  }
}
